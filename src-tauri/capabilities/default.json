{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main, Analyzer and tab windows",
  "windows": ["main", "analyzer-view","tab-view"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:webview:allow-create-webview-window",
    "opener:default"
  ]
}
