{
  "name": "rustriff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-types": "cargo tauri-typegen generate --output-path ./src/domain && npm run generate-effect-types",
    "generate-effect-types": "node scripts/generate-effect-types.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "docs:generateRustDocs": "cd src-tauri && cargo doc --no-deps --target-dir ../docs/public/backend",
    "docs:generateReactDocs": "typedoc --out docs/public/frontend",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "chroma-js": "^3.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-react": "^0.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "vite": "^7.0.4"
  }
}
