{
  "name": "rustriff",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "format-rust": "cd ./src-tauri && cargo fmt --all",
    "clippy-rust": "cd ./src-tauri && cargo clippy --all-targets --all-features -- ",
    "generate-types": "cargo tauri-typegen generate --output-path ./src/domain && npm run generate-effect-types",
    "generate-effect-types": "node scripts/generate-effect-types.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "npm run test:rust && npm run test:ui",
    "test:rust": "cd ./src-tauri && cargo test",
    "test:rust-mutation": "cd ./src-tauri && cargo mutants",
    "test:ui": "vitest run",
    "test:ui-ui": "vitest run --ui --watch",
    "test:ui-coverage": "vitest run --coverage",
    "test:ui-mutation": "stryker run",
    "test:ui-mutation:dry": "stryker run --dryRunOnly",
    "docs:generateRustDocs": "cd src-tauri && cargo doc --no-deps --target-dir ../docs/public/backend",
    "docs:generateReactDocs": "typedoc --out docs/public/frontend",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^3.9.0",
    "@mdit/plugin-katex": "^0.25.2",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "chroma-js": "^3.2.0",
    "katex": "^0.16.45",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^7.14.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-react": "^0.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^7.0.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "vite": "^7.0.4"
  }
}
